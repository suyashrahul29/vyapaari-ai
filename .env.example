# Copy this file to .env.local and fill in real values. Do NOT commit .env.local.

# Supabase project URL (used by both browser and server clients)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Supabase anon/public key (browser auth client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Supabase service-role key (server-side, privileged — keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Gemini API key (embeddings via gemini-embedding-001)
GEMINI_API_KEY=your-gemini-api-key-here

# Groq API key (LLM chat + speech-to-text)
GROQ_API_KEY=your-groq-api-key-here

# Sarvam API key (text-to-speech)
SARVAM_API_KEY=your-sarvam-api-key-here
